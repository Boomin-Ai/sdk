{
  "name": "boomin-sdk",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "boomin-sdk",
      "workspaces": [
        "packages/cli",
        "packages/connect",
        "packages/server"
      ]
    },
    "node_modules/@boomin/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@boomin/connect": {
      "resolved": "packages/connect",
      "link": true
    },
    "node_modules/@boomin/server": {
      "resolved": "packages/server",
      "link": true
    },
    "packages/cli": {
      "name": "@boomin/cli",
      "version": "0.1.6",
      "license": "UNLICENSED",
      "bin": {
        "boomin": "src/cli.js"
      }
    },
    "packages/connect": {
      "name": "@boomin/connect",
      "version": "0.1.1",
      "license": "UNLICENSED"
    },
    "packages/server": {
      "name": "@boomin/server",
      "version": "0.1.1",
      "license": "UNLICENSED"
    }
  }
}

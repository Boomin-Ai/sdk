{
  "name": "boomin-sdk",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "boomin-sdk",
      "workspaces": [
        "packages/cli",
        "packages/connect",
        "packages/server",
        "packages/mcp",
        "packages/boomin"
      ]
    },
    "node_modules/@boomin/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@boomin/connect": {
      "resolved": "packages/connect",
      "link": true
    },
    "node_modules/@boomin/mcp": {
      "resolved": "packages/mcp",
      "link": true
    },
    "node_modules/@boomin/server": {
      "resolved": "packages/server",
      "link": true
    },
    "node_modules/boominjs": {
      "resolved": "packages/boomin",
      "link": true
    },
    "packages/boomin": {
      "name": "boominjs",
      "version": "0.3.5",
      "license": "UNLICENSED",
      "dependencies": {
        "@boomin/cli": "file:../cli",
        "@boomin/connect": "file:../connect",
        "@boomin/server": "file:../server"
      },
      "bin": {
        "boominjs": "src/cli.js"
      }
    },
    "packages/cli": {
      "name": "@boomin/cli",
      "version": "0.1.6",
      "license": "UNLICENSED",
      "bin": {
        "boomin": "src/cli.js",
        "boominjs": "src/cli.js"
      }
    },
    "packages/connect": {
      "name": "@boomin/connect",
      "version": "0.1.1",
      "license": "UNLICENSED"
    },
    "packages/mcp": {
      "name": "@boomin/mcp",
      "version": "0.1.0",
      "license": "UNLICENSED",
      "bin": {
        "boomin-mcp": "src/stdio.js"
      }
    },
    "packages/server": {
      "name": "@boomin/server",
      "version": "0.1.1",
      "license": "UNLICENSED"
    }
  }
}

{
  "name": "@boomin/mcp",
  "version": "0.1.0",
  "description": "Boomin MCP server for agent-native referral program installation and program operation.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Boomin-Ai/sdk.git",
    "directory": "packages/mcp"
  },
  "bin": {
    "boomin-mcp": "src/stdio.js"
  },
  "exports": {
    ".": {
      "import": "./src/protocol.js",
      "default": "./src/protocol.js"
    },
    "./stdio": {
      "import": "./src/stdio.js",
      "default": "./src/stdio.js"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "node --check src/protocol.js && node --check src/stdio.js",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "boomin",
    "mcp",
    "agents",
    "partner-connect",
    "referral"
  ],
  "author": "Boomin",
  "license": "UNLICENSED"
}

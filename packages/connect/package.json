{
  "name": "@boomin/connect",
  "version": "0.1.1",
  "description": "Browser SDK for Boomin Partner Connect.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Boomin-Ai/sdk.git",
    "directory": "packages/connect"
  },
  "main": "./src/index.js",
